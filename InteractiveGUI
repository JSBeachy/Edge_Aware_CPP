        self.current_stage = stage
        self._reset_corners_button.enabled = (stage == "corner_selection")
        self._confirm_corners_button.enabled = (stage == "corner_selection")
        self._confirm_edges_button.enabled = (stage == "edge_selection")
        is_param_inp = stage == "parameter_input"
        self._probe_width_input.enabled = is_param_inp
        self._spacing_input.enabled = is_param_inp
        self._shift_input.enabled = is_param_inp
        self._generate_button.enabled = is_param_inp
        self._calculate_scan_button.enabled = (stage == "paths_generated")

        if is_param_inp:
            self._probe_width_input.int_value = 64
            self._spacing_input.int_value = 1
            self._shift_input.double_value = self._probe_width_input.int_value/2

    def _on_reset_corners(self):
        """Resets the corners to the automatically detected ones."""
        if self.CPP and self.CPP.ordered_edge_points2D is not None:
            dps = self.CPP.dot_product(self.CPP.ordered_edge_points2D)
            self.corner_indices = list(np.argsort(np.abs(dps))[:4])
            self._update_corner_visualization()

    def _on_confirm_corners(self):
        if len(self.corner_indices)<2:
            self.window.show_message_box("Error","Please select at least 2 corners")
            return
        #print(f"Corners confirmed at indices: {sorted(self.corner_indices)}")
        def task():
            self._scene.scene.remove_geometry("__selected_edges")
            self._scene.scene.remove_geometry("__corners")
            #re-run perimeter calculations with new edge-points, could streamline and only run split boundary
            self.CPP.boundary_edge_calculations(alt_corner_indicies=self.corner_indices)
            self._setup_and_visualize_edge_points()
            self._set_ui_for_stage("edge_selection")
        gui.Application.instance.post_to_main_thread(self.window, task)

    def _setup_and_visualize_edge_points(self):
        '''Create a lookup dictionary from a boundary point index to its edge segement index'''
        self.only_edge_point_dic={}
        self.edge_point_groups = {}
        #iterate through list to assign:
        # - edge point tuples with their edge as a key
        # - edges with all edge point tuples as key
        #Then selected points will return what their edge is (from only_edge_point_dic)
        #and edges can rapidly be added to visualization (with edge_point_groups)
        for i, edge in enumerate(self.CPP.all_edges):
            points_in_edge=[]
            for point in edge[1:-1]: #takes out the corners from the edge groups
                point_tuple=tuple(point)
                self.only_edge_point_dic[point_tuple]=i
                points_in_edge.append(point)
            self.edge_point_groups[i]=points_in_edge
        
        index_1= self.only_edge_point_dic.get(tuple(self.CPP.edges[0][1]))
        index_2 = self.only_edge_point_dic.get(tuple(self.CPP.edges[1][1]))
        self.selected_edges=[index_1,index_2]
        self._update_boundary_visualization()

    def _on_confirm_edges(self):
        #print(f"Confirmed Edges: {sorted(self.selected_edges)}")
        if len(self.selected_edges) != 2:
            self.window.show_message_box("Error", "Please select exactly 2 edges")
            return
        def task():
            edge1=self.CPP.all_edges[self.selected_edges[0]]
            edge2=self.CPP.all_edges[self.selected_edges[1]]
            if np.mean(edge1 @ self.CPP.secondary_axis) > np.mean(edge2 @ self.CPP.secondary_axis):
                edge1, edge2 = edge2, edge1

            self.CPP.edges=[edge1,edge2]
            # Get the direction vector of each edge
            dir1 = edge1[-1] - edge1[0]
            dir2 = edge2[-1] - edge2[0]

            # Check if their directions are aligned with the primary PCA axis
            dot1 = np.dot(dir1, self.CPP.primary_axis)
            dot2 = np.dot(dir2, self.CPP.primary_axis)

            # If the signs are different, one edge is running backwards. Reverse it.
            if np.sign(dot1) != np.sign(dot2):
                self.CPP.edges[1] = self.CPP.edges[1][::-1]
            
            self._scene.scene.remove_geometry("__full_boundary")
            self._scene.scene.remove_geometry("__selected_edges")
            self._set_ui_for_stage("parameter_input")
        gui.Application.instance.post_to_main_thread(self.window,task)


    def _update_boundary_visualization(self):
        self._scene.scene.remove_geometry("__selected_edges")
        if self.CPP and self.selected_edges:
            all_edge_points=[]
            for edge_idx in self.selected_edges:
                if edge_idx in self.edge_point_groups:
                    all_edge_points.extend(self.edge_point_groups[edge_idx])

            if not all_edge_points:
                return
            boundaries= o3d.utility.Vector3dVector(np.asarray(all_edge_points))
            boundary_cloud=o3d.geometry.PointCloud(boundaries)
            mat = rendering.MaterialRecord()
            mat.shader= "defaultUnlit"
            mat.point_size=5.0
            mat.base_color = [1, 0.5, 0.0, 1.0]
            self._scene.scene.add_geometry("__selected_edges",boundary_cloud, mat)

    def _update_corner_visualization(self):
        self._scene.scene.remove_geometry("__corners")
        if self.CPP and self.corner_indices:
            corner_points=self.CPP.ordered_edge_points[self.corner_indices]
            corner_cloud=o3d.geometry.PointCloud(o3d.utility.Vector3dVector(corner_points))
            mat=rendering.MaterialRecord()
            mat.shader= "defaultUnlit"
            mat.point_size=12.0
            mat.base_color=[1.0, 0.8, 0, 1]
            self._scene.scene.add_geometry("__corners", corner_cloud, mat)

    def _on_mouse_widget3d(self,event):
        if event.type == gui.MouseEvent.Type.BUTTON_DOWN and event.buttons & int(gui.MouseButton.RIGHT):
            self._last_mouse_xy = (event.x, event.y)
            if self.current_stage == "corner_selection":
                self._scene.scene.scene.render_to_depth_image(self.depth_callback)
                return gui.Widget.EventCallbackResult.HANDLED
            elif self.current_stage == "edge_selection":
                self._scene.scene.scene.render_to_depth_image(self.depth_callback)
                return gui.Widget.EventCallbackResult.HANDLED
        return gui.Widget.EventCallbackResult.IGNORED
    
    def depth_callback(self, depth_image):
        x, y = self._last_mouse_xy
        widget_x = x - self._scene.frame.x
        widget_y = y - self._scene.frame.y
        depth = np.asarray(depth_image)[widget_y, widget_x]
        if depth == 1.0: 
            return
        world = self._scene.scene.camera.unproject(widget_x, widget_y, depth, self._scene.frame.width, self._scene.frame.height)
        #we use the same kd-tree for both searches
        [k, idx, _] = self.boundary_kdtree.search_knn_vector_3d(world, 1)
        if k > 0:
            if self.current_stage == "corner_selection":
                boundary_index = idx[0]
                if boundary_index in self.corner_indices: 
                    self.corner_indices.remove(boundary_index)
                else: 
                    self.corner_indices.append(boundary_index)
                gui.Application.instance.post_to_main_thread(self.window, self._update_corner_visualization)

            elif self.current_stage == "edge_selection":
                tup=self.CPP.ordered_edge_points[idx[0]]
                val=self.only_edge_point_dic.get(tuple(tup))
                if val in self.selected_edges:
                    self.selected_edges.remove(val)
                else:
                    self.selected_edges.append(val)

                gui.Application.instance.post_to_main_thread(self.window, self._update_boundary_visualization)


    def _on_generate(self):
            self._scene.scene.remove_geometry("__path_preview")
            probe_width = self._probe_width_input.int_value
            slice_res = self._spacing_input.int_value
            custom_shift = self._shift_input.double_value

            self.CPP.edge_fitter(self.CPP.edges)
            self.CPP.scan_information(probe_width, slice_res, edge_offset=custom_shift if custom_shift > 0 else None)
            self.CPP.shift_direction()
            shift_vec = self.CPP.offset_one * self.CPP.secondary_axis
            self.CPP.edge1_CP = self.CPP.edge1_CP - self.CPP.offset_dir * shift_vec
            self.CPP.edge2_CP = self.CPP.edge2_CP + self.CPP.offset_dir * shift_vec

            passes, colors = self.CPP.line_interpolator(slice_res)
            self.generated_passes = (passes, colors)

                # Visualize the path preview
            if passes:
                pass_points = o3d.geometry.PointCloud(o3d.utility.Vector3dVector(np.vstack(passes)))
                pass_points.colors = o3d.utility.Vector3dVector(np.vstack(colors))

                mat = rendering.MaterialRecord()
                mat.shader = "defaultUnlit"
                mat.point_size = 5.0
                self._scene.scene.add_geometry("__path_preview", pass_points, mat)

            self._set_ui_for_stage("paths_generated")
        
    def _on_calculate_scan_area(self):
        if not self.generated_passes:
            self.window.show_message_box("Error", "Please generate paths first.")
            return 
        #Clear the pre
        redundant, on_surface, on_surface_color = self.CPP.local_scanned_area(Redundancy=True, Elimination=False)
        
        self.CPP.mesh.vertex_colors = o3d.utility.Vector3dVector(self.CPP.colors)
        self._scene.scene.remove_geometry("__model__")
        self._scene.scene.add_geometry("__model__", self.CPP.mesh, self.settings.material)

        if on_surface:
            valid_passes = [p for p in on_surface if p.size > 0]
            if valid_passes:
                pass_points = o3d.geometry.PointCloud(o3d.utility.Vector3dVector(np.vstack(valid_passes)))
                pass_points.colors = o3d.utility.Vector3dVector(np.vstack([c for c, p in zip(on_surface_color, on_surface) if p.size > 0]))
                mat = rendering.MaterialRecord(); mat.shader = "defaultUnlit"; mat.point_size = 5.0
                self._scene.scene.add_geometry("scan_paths", pass_points, mat)
        
        self.window.show_message_box("Success", "Scan path generation complete.")
        self._set_ui_for_stage("start")

def main():
    gui.Application.instance.initialize()
    w = AppWindow(1024, 768)
    if len(sys.argv) > 1:
        path = sys.argv[1]
        if os.path.exists(path):
            w.load(path)
        else:
            w.window.show_message_box("Error", "Could not open file '" + path + "'")
    # Run the event loop. This will not return until the last window is closed.
    gui.Application.instance.run()

if __name__ == "__main__":
    main()
