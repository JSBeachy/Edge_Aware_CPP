    def load(self, path):
        #Reset planning
        self._scene.scene.clear_geometry()
        self.corner_indices=[]
        self.selected_edges=[]
        self.CPP= None
        self.boundary_kdtree= None
        try:
            self.CPP = Best_Fit_CPP(path)
            # Add the main mesh to the scene first
            self._scene.scene.add_geometry("__model__", self.CPP.mesh, self.settings.material)
            bounds = self._scene.scene.bounding_box
            self._scene.setup_camera(60, bounds, bounds.get_center())
            # Now run analysis and check for boundaries
            self.CPP.boundary_edge_calculations()
            if self.CPP.ordered_edge_points is None or len(self.CPP.ordered_edge_points) == 0:
                self.window.show_message_box("Info", "Mesh has no open boundary for path planning.")
                self._set_ui_for_stage("start")
                return
            boundary_pcd = o3d.geometry.PointCloud(o3d.utility.Vector3dVector(self.CPP.ordered_edge_points))
            self.boundary_kdtree = o3d.geometry.KDTreeFlann(boundary_pcd)
            dps = self.CPP.dot_product(self.CPP.ordered_edge_points2D)
            self.corner_indices = list(np.argsort(np.abs(dps))[:4])
            self._visualize_full_boundary()
            self._update_corner_visualization()
            self._set_ui_for_stage("corner_selection")
            
        except Exception as e:
            print(e)
            self.window.show_message_box("Error", f"Failed to load or process '{path}':\n{e}")
            self._set_ui_for_stage("start")
            

    def _visualize_full_boundary(self):
        """Draws all boundary points in a neutral color."""
        self._scene.scene.remove_geometry("__full_boundary")
        if self.CPP and self.CPP.ordered_edge_points is not None:
            boundary_cloud = o3d.geometry.PointCloud(
                o3d.utility.Vector3dVector(self.CPP.ordered_edge_points))
            mat = rendering.MaterialRecord()
            mat.shader = "defaultUnlit"
            mat.point_size = 5.0
            mat.base_color = [0.5, 0.5, 0.5, 1.0]  # Grey color
            self._scene.scene.add_geometry("__full_boundary", boundary_cloud, mat)



